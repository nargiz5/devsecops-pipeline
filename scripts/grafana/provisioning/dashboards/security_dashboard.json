{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "type": "stat",
      "title": "High & Critical Total",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": "DefectDojo_Postgres",
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT count(*) as total FROM dojo_finding WHERE severity IN ('High', 'Critical') AND active = true;",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "type": "piechart",
      "title": "Vulnerability Distribution",
      "gridPos": { "h": 6, "w": 10, "x": 6, "y": 0 },
      "datasource": "DefectDojo_Postgres",
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT severity, count(*) as total FROM dojo_finding WHERE active = true GROUP BY severity;",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "values": true },
        "displayLabels": ["percent"]
      }
    },
    {
      "type": "table",
      "title": "Recent Vulnerabilities List",
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 6 },
      "datasource": "DefectDojo_Postgres",
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT title as \"Finding\", severity as \"Severity\", component_name as \"Component\", date as \"Date\" FROM dojo_finding WHERE active = true ORDER BY date DESC LIMIT 10;",
          "refId": "A"
        }
      ]
    }
  ],
  "title": "Security Overview",
  "schemaVersion": 36
}
